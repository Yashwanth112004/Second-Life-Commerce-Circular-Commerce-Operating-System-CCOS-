# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---- Database (PostgreSQL) ----
# Matches docker-compose.yml (mapped to host port 5433 to avoid clashing with a local Postgres).
DATABASE_URL=postgres://ccos:ccos_dev_password@localhost:5433/ccos

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret-in-prod
JWT_REFRESH_SECRET=change-me-refresh-secret-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- AI (OpenRouter) ----
# Get a free key at https://openrouter.ai/keys . Put the real key in .env (gitignored), NOT here.
# When unset: text AI returns a flagged fallback; vision returns "unavailable" (never fabricates damage).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Text reasoning: listings, root-cause, coach, narratives, seller/buyer insights.
TEXT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Vision: damage detection + condition grading. Receives the actual uploaded images (base64).
VISION_MODEL=qwen/qwen3-vl-8b-instruct
VISION_FALLBACK_MODEL=meta-llama/llama-3.2-11b-vision-instruct

# ---- File storage ----
# STORAGE_DRIVER=local uses ./uploads (served at /uploads). Set to "cloudinary" for CDN.
STORAGE_DRIVER=local
CLOUDINARY_URL=

# ---- Seed ----
SEED_DEMO_PASSWORD=Password123!
